# Use Gemini as the primary provider
LLM_PROVIDER=gemini

# Your Gemini API key from ai.google.dev
GOOGLE_API_KEY="00"

# Pick a Gemini model (flash=fast/cheap, pro=stronger)
GEMINI_MODEL=gemini-1.5-flash
# or: GEMINI_MODEL=gemini-1.5-flash

# Local fallback settings (used only if Gemini fails)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# (optional) vector store choice you already support
VECTOR_BACKEND=faiss_gpu
