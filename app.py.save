  <div class="flex">
    <div><label>Desired Outcomes (one per line)</label><textarea id="desired" rows="6"></textarea></div>
    <div><label>Purpose of RFT (one per line)</label><textarea id="purpose" rows="6"></textarea></div>
  </div>
</div>

<div class="card">
  <h3>Probity & Accountability</h3>
  <div class="flex">
    <div><label>Contact Officer – Name</label><input id="co_name" type="text"/></div>
    <div><label>Title</label><input id="co_title" type="text"/></div>
    <div><label>Email</label><input id="co_email" type="text"/></div>
    <div><label>Phone</label><input id="co_phone" type="text"/></div>
  </div>
  <label>Receipt of Tenders (one per line)</label><textarea id="receipt" rows="3"></textarea>
  <label>Late Tenders (one per line)</label><textarea id="late" rows="3"></textarea>
  <label>Requests for Clarification (one per line)</label><textarea id="clar" rows="3"></textarea>

  <h4>Critical Issues / Risks</h4>
  <table id="risks">
    <tr><th>Issue</th><th>Consequence</th><th>Action</th><th></th></tr>
  </table>
  <button class="btn" onclick="addRisk()">Add Risk</button>
</div>

<div class="card">
  <h3>Evaluation Committee</h3>
  <table id="committee">
    <tr><th>Name</th><th>Title</th><th>Branch</th><th>Role</th><th></th></tr>
  </table>
  <button class="btn" onclick="addMember()">Add Member</button>
</div>

<div class="card">
  <h3>Evaluation Schedule</h3>
  <table id="sched">
    <tr><th>Task</th><th>Responsible</th><th>Due</th><th></th></tr>
  </table>
  <button class="btn" onclick="addSched()">Add Schedule Item</button>
</div>

<div class="card">
  <h3>Evaluation Methodology</h3>
  <label>Compliance Criteria (unweighted, one per line)</label><textarea id="comp" rows="5"></textarea>

  <h4>Required Criteria (weighted)</h4>
  <table id="reqc">
    <tr><th>Name</th><th>Weight</th><th>Description</th><th>Mandatory</th><th></th></tr>
  </table>
  <button class="btn" onclick="addReq()">Add Criterion</button>

  <label>Rating Scale (one per line)</label><textarea id="scale" rows="4"></textarea>
</div>

<div class="card">
  <h3>Returnable Schedules Scoring</h3>
  <p class="small">Edit scoring rubrics (each line like "Level | Requirement | Score").</p>
  <div class="flex">
    <div><label>Relevant Experience</label><textarea id="rs_exp" rows="6"></textarea></div>
    <div><label>Capability</label><textarea id="rs_cap" rows="6"></textarea></div>
  </div>
  <div class="flex">
    <div><label>Quality</label><textarea id="rs_qm" rows="6"></textarea></div>
    <div><label>WHS</label><textarea id="rs_whs" rows="6"></textarea></div>
  </div>
</div>

<div class="card">
  <h3>Pricing</h3>
  <label>Formulae (one per line)</label><textarea id="price_formulae" rows="4"></textarea>
  <label>Variables (comma-separated)</label><input id="price_vars" type="text"/>

  <h4>Local Preference Policy</h4>
  <div class="flex">
    <div><label>Blacktown LGA</label><input id="lp_bcc" type="text" placeholder="e.g. 5% capped at $50,000"/></div>
    <div><label>Western Sydney</label><input id="lp_ws" type="text" placeholder="e.g. 2.5% capped at $25,000"/></div>
  </div>
  <label>Notes (one per line)</label><textarea id="lp_notes" rows="3"></textarea>

  <label>Value for Money (one per line)</label><textarea id="vfm" rows="3"></textarea>
</div>

<div class="card">
  <h3>Other Sections</h3>
  <label>Interviews / Presentations (one per line)</label><textarea id="ip" rows="3"></textarea>
  <label>Short-listing / Alternatives (one per line)</label><textarea id="short" rows="3"></textarea>
  <label>Evaluation Report (one per line)</label><textarea id="erep" rows="3"></textarea>
  <label>Contract Negotiations (one per line)</label><textarea id="neg" rows="3"></textarea>
  <label>Debriefing (one per line)</label><textarea id="deb" rows="3"></textarea>
  <label>Contract Management (one per line)</label><textarea id="cm" rows="3"></textarea>
  <label>Critical Dates (one per line)</label><textarea id="cdates" rows="3"></textarea>
</div>

<div>
  <button class="btn" onclick="save()">Save</button>
  <a class="btn" id="homeLink" href="/">Back to Home</a>
</div>

<script>
const recId = location.pathname.split('/').pop();
document.getElementById('backlink').href = '/?recId=' + encodeURIComponent(recId);
document.getElementById('homeLink').href = '/?recId=' + encodeURIComponent(recId);

let data=null;

function T(id,v){document.getElementById(id).value = v||'';}
function V(id){return document.getElementById(id).value.trim();}
function L(id){return V(id)? V(id).split('\\n').map(x=>x.trim()).filter(Boolean):[];}

function renderCommittee(){
  const tb=document.getElementById('committee'); tb.innerHTML='<tr><th>Name</th><th>Title</th><th>Branch</th><th>Role</th><th></th></tr>';
  (data.evaluation_committee||[]).forEach((m,i)=>{
    const r=tb.insertRow();
    r.insertCell().innerHTML=`<input value="${m.name||''}" oninput="setMember(${i},'name',this.value)" />`;
    r.insertCell().innerHTML=`<input value="${m.title||''}" oninput="setMember(${i},'title',this.value)" />`;
    r.insertCell().innerHTML=`<input value="${m.branch||''}" oninput="setMember(${i},'branch',this.value)" />`;
    r.insertCell().innerHTML=`<input value="${m.role||''}" oninput="setMember(${i},'role',this.value)" />`;
    r.insertCell().innerHTML=`<button onclick="delMember(${i})">Delete</button>`;
  });
}
function addMember(){ (data.evaluation_committee = data.evaluation_committee||[]).push({}); renderCommittee(); }
function setMember(i,k,v){ data.evaluation_committee[i][k]=v; }
function delMember(i){ data.evaluation_committee.splice(i,1); renderCommittee(); }

function renderSched(){
  const tb=document.getElementById('sched'); tb.innerHTML='<tr><th>Task</th><th>Responsible</th><th>Due</th><th></th></tr>';
  (data.evaluation_schedule||[]).forEach((m,i)=>{
    const r=tb.insertRow();
    r.insertCell().innerHTML=`<input value="${m.task||''}" oninput="setSched(${i},'task',this.value)" />`;
    r.insertCell().innerHTML=`<input value="${m.responsible||''}" oninput="setSched(${i},'responsible',this.value)" />`;
    r.insertCell().innerHTML=`<input value="${m.due||''}" oninput="setSched(${i},'due',this.value)" />`;
    r.insertCell().innerHTML=`<button onclick="delSched(${i})">Delete</button>`;
  });
}
function addSched(){ (data.evaluation_schedule=data.evaluation_schedule||[]).push({task:''}); renderSched(); }
function setSched(i,k,v){ data.evaluation_schedule[i][k]=v; }
function delSched(i){ data.evaluation_schedule.splice(i,1); renderSched(); }

function renderReq(){
  const tb=document.getElementById('reqc'); tb.innerHTML='<tr><th>Name</th><th>Weight</th><th>Description</th><th>Mandatory</th><th></th></tr>';
  const rc=(data.evaluation_methodology?.required_criteria)||[];
  rc.forEach((c,i)=>{
    const r=tb.insertRow();
    r.insertCell().innerHTML=`<input value="${c.name||''}" oninput="setReq(${i},'name',this.value)" />`;
    r.insertCell().innerHTML=`<input value="${c.weight??''}" oninput="setReq(${i},'weight',this.value)" />`;
    r.insertCell().innerHTML=`<input value="${c.description||''}" oninput="setReq(${i},'description',this.value)" />`;
    r.insertCell().innerHTML=`<input type="checkbox" ${c.mandatory?'checked':''} onchange="setReq(${i},'mandatory',this.checked)" />`;
    r.insertCell().innerHTML=`<button onclick="delReq(${i})">Delete</button>`;
  });
}
function addReq(){ const rc=(data.evaluation_methodology.required_criteria=data.evaluation_methodology.required_criteria||[]); rc.push({name:'New',weight:0,description:'',mandatory:false}); renderReq(); }
function setReq(i,k,v){ if(k==='weight') v=parseFloat(v)||0; data.evaluation_methodology.required_criteria[i][k]=v; }
function delReq(i){ data.evaluation_methodology.required_criteria.splice(i,1); renderReq(); }

function renderRisks(){
  const tb=document.getElementById('risks'); tb.innerHTML='<tr><th>Issue</th><th>Consequence</th><th>Action</th><th></th></tr>';
  const rk=(data.probity_and_accountability?.risks)||[];
  rk.forEach((r,i)=>{
    const row=tb.insertRow();
    row.insertCell().innerHTML=`<input value="${r.issue||''}" oninput="setRisk(${i},'issue',this.value)" />`;
    row.insertCell().innerHTML=`<input value="${r.consequence||''}" oninput="setRisk(${i},'consequence',this.value)" />`;
    row.insertCell().innerHTML=`<input value="${r.action||''}" oninput="setRisk(${i},'action',this.value)" />`;
    row.insertCell().innerHTML=`<button onclick="delRisk(${i})">Delete</button>`;
  });
}
function addRisk(){ const rk=(data.probity_and_accountability=data.probity_and_accountability||{}, data.probity_and_accountability.risks=data.probity_and_accountability.risks||[]); rk.push({issue:'',consequence:'',action:''}); renderRisks(); }
function setRisk(i,k,v){ data.probity_and_accountability.risks[i][k]=v; }
function delRisk(i){ data.probity_and_accountability.risks.splice(i,1); renderRisks(); }

function linesFromRubric(r){
  return (r.levels||[]).map(x => [x.level||'', x.requirement||'', (x.score??'')].join(' | ')).join('\\n');
}
function rubricFromLines(txt){
  return {levels: (txt? txt.split('\\n').map(s=>s.trim()).filter(Boolean):[]).map(line=>{
    const parts=line.split('|').map(x=>x.trim());
    return {level:parts[0]||'', requirement:parts[1]||'', score: parseFloat(parts[2]||'')||0};
  })};
}

async function load(){
  const r = await fetch('/records/'+recId+'/tepp'); data = await r.json();
  // header
  T('p_title', data.header?.project_title); T('t_no', data.header?.tender_no); T('roles', (data.header?.panel_roles||[]).join(', '));
  // aim/description
  document.getElementById('aim').value = (data.aim||[]).join('\\n');
  document.getElementById('desc_summary').value = (data.description?.summary||[]).join('\\n');
  document.getElementById('desired').value = (data.description?.desired_outcomes||[]).join('\\n');
  document.getElementById('purpose').value = (data.description?.purpose_rft||[]).join('\\n');
  // probity & accountability
  const co = data.probity_and_accountability?.authorised_contact_officer||{};
  T('co_name', co.name); T('co_title', co.title); T('co_email', co.email); T('co_phone', co.phone);
  document.getElementById('receipt').value = (data.probity_and_accountability?.receipt_of_tenders||[]).join('\\n');
  document.getElementById('late').value = (data.probity_and_accountability?.late_tenders||[]).join('\\n');
  document.getElementById('clar').value = (data.probity_and_accountability?.clarifications||[]).join('\\n');
  renderRisks();
  // committees/schedule
  renderCommittee(); renderSched();
  // methodology
  document.getElementById('comp').value = (data.evaluation_methodology?.compliance_criteria||[]).join('\\n');
  renderReq();
  document.getElementById('scale').value = (data.evaluation_methodology?.rating_scale||[]).join('\\n');
  // scoring rubrics
  document.getElementById('rs_exp').value = linesFromRubric(data.returnable_scoring?.relevant_experience||{});
  document.getElementById('rs_cap').value = linesFromRubric(data.returnable_scoring?.capability||{});
  document.getElementById('rs_qm').value  = linesFromRubric(data.returnable_scoring?.quality||{});
  document.getElementById('rs_whs').value = linesFromRubric(data.returnable_scoring?.whs||{});
  // pricing
  document.getElementById('price_formulae').value = (data.pricing?.model?.formulae||[]).join('\\n');
  document.getElementById('price_vars').value = (data.pricing?.model?.variables||[]).join(', ');
  T('lp_bcc', data.pricing?.local_preference_policy?.blacktown_lga_discount);
  T('lp_ws', data.pricing?.local_preference_policy?.western_sydney_discount);
  document.getElementById('lp_notes').value = (data.pricing?.local_preference_policy?.notes||[]).join('\\n');
  document.getElementById('vfm').value = (data.pricing?.value_for_money||[]).join('\\n');
  // other sections
  document.getElementById('ip').value = (data.interviews_presentations||[]).join('\\n');
  document.getElementById('short').value = (data.shortlisting_alternatives||[]).join('\\n');
  document.getElementById('erep').value = (data.evaluation_report||[]).join('\\n');
  document.getElementById('neg').value = (data.contract_negotiations||[]).join('\\n');
  document.getElementById('deb').value = (data.debriefing||[]).join('\\n');
  document.getElementById('cm').value = (data.contract_management||[]).join('\\n');
  document.getElementById('cdates').value = (data.critical_dates||[]).join('\\n');


async function save(){
  // header
w  data.header = { project_title: V('p_title'), tender_no: V('t_no'), panel_roles: V('roles')? V('roles').split(',').map(x=>x.trim()):[] };
  // aim/description
  data.aim = L('aim');
  data.description = { summary: L('desc_summary'), desired_outcomes: L('desired'), purpose_rft: L('purpose') };
  // probity & accountability
  data.probity_and_accountability = data.probity_and_accountability||{};
  data.probity_and_accountability.authorised_contact_officer = { name: V('co_name'), title: V('co_title'), email: V('co_email'), phone: V('co_phone') };
  data.probity_and_accountability.receipt_of_tenders = L('receipt');
  data.probity_and_accountability.late_tenders = L('late');
  data.probity_and_accountability.clarifications = L('clar');
  // committees/schedule/methodology/risk & rubrics changes already bound via setters & save below
  data.evaluation_methodology = data.evaluation_methodology||{};
  data.evaluation_methodology.compliance_criteria = L('comp');
  data.evaluation_methodology.rating_scale = L('scale');
  data.returnable_scoring = {
    relevant_experience: rubricFromLines(document.getElementById('rs_exp').value),
    capability: rubricFromLines(document.getElementById('rs_cap').value),
    quality: rubricFromLines(document.getElementById('rs_qm').value),
    whs: rubricFromLines(document.getElementById('rs_whs').value)
  };
  // pricing
  data.pricing = data.pricing||{};
  data.pricing.model = { formulae: L('price_formulae'), variables: V('price_vars')? V('price_vars').split(',').map(x=>x.trim()):[] };
  data.pricing.local_preference_policy = {
    blacktown_lga_discount: V('lp_bcc'), western_sydney_discount: V('lp_ws'),
    notes: L('lp_notes')
  };
  data.pricing.value_for_money = L('vfm');
  // other sections
  data.interviews_presentations = L('ip');
  data.shortlisting_alternatives = L('short');
  data.evaluation_report = L('erep');
  data.contract_negotiations = L('neg');
  data.debriefing = L('deb');
  data.contract_management = L('cm');
  data.critical_dates = L('cdates');

  await fetch('/records/'+recId+'/tepp',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({data})});
  alert('Saved');
}

function addReq(){ const rc=(data.evaluation_methodology=data.evaluation_methodology||{}, data.evaluation_methodology.required_criteria=data.evaluation_methodology.required_criteria||[]); rc.push({name:'New',weight:0,description:'',mandatory:false}); renderReq(); }
function delReq(i){ data.evaluation_methodology.required_criteria.splice(i,1); renderReq(); }

function addRisk(){ const rk=(data.probity_and_accountability=data.probity_and_accountability||{}, data.probity_and_accountability.risks=data.probity_and_accountability.risks||[]); rk.push({issue:'',consequence:'',action:''}); renderRisks(); }
function delRisk(i){ data.probity_and_accountability.risks.splice(i,1); renderRisks(); }

function addMember(){ (data.evaluation_committee = data.evaluation_committee||[]).push({}); renderCommittee(); }
function delMember(i){ data.evaluation_committee.splice(i,1); renderCommittee(); }

function addSched(){ (data.evaluation_schedule=data.evaluation_schedule||[]).push({task:''}); renderSched(); }
function delSched(i){ data.evaluation_schedule.splice(i,1); renderSched(); }

function setMember(i,k,v){ data.evaluation_committee[i][k]=v; }
function setSched(i,k,v){ data.evaluation_schedule[i][k]=v; }
function setReq(i,k,v){ if(k==='weight') v=parseFloat(v)||0; data.evaluation_methodology.required_criteria[i][k]=v; }
function setRisk(i,k,v){ data.probity_and_accountability.risks[i][k]=v; }

window.addEventListener('load', load);
</script></body></html>
"""

# -------------------- Structured Returnables Editor --------------------
EDITOR_RS2 = r"""
<!doctype html><html><head><meta charset="utf-8"/>
<title>Returnables (Structured)</title><meta name="viewport" content="width=device-width, initial-scale=1"/>
<style>
body{font-family:system-ui;-apple-system,Segoe UI,Roboto,sans-serif;max-width:1100px;margin:22px auto;padding:0 16px}
.card{border:1px solid #ddd;border-radius:12px;padding:16px;margin:10px 0}
.btn{padding:8px 12px;border:0;border-radius:10px;background:#111;color:#fff;cursor:pointer}
table{width:100%;border-collapse:collapse} td,th{border:1px solid #ddd;padding:8px}
</style></head><body>
<h2>Returnable Schedules – Structured</h2>
<a class="btn" id="back">← Back</a>

<div class="card">
  <h3>Schedule 9 – Delivery Performance (Milestones)</h3>
  <table id="ms"><tr><th>Milestone</th><th>Start</th><th>End</th><th></th></tr></table>
  <button class="btn" onclick="addMs()">Add Milestone</button>
</div>

<div class="card">
  <h3>Schedule 10 – Chiller Performance (key fields)</h3>
  <div id="ch"></div>
</div>

<div class="card">
  <h3>Schedule 10 – Pricing Lines</h3>
  <table id="pl"><tr><th>Item</th><th>Details</th><th>ex GST</th><th>GST</th><th>inc GST</th><th></th></tr></table>
  <button class="btn" onclick="addPl()">Add Line</button>
</div>

<button class="btn" onclick="save()">Save</button>
<script>
const recId = location.pathname.split('/').pop();
document.getElementById('back').href='/?recId='+encodeURIComponent(recId);
let data=null;
function td(r,html){const c=r.insertCell(); c.innerHTML=html; return c;}

function render(){
  const tb=document.getElementById('ms');
  tb.innerHTML='<tr><th>Milestone</th><th>Start</th><th>End</th><th></th></tr>';
  (data.schedule_9_milestones||[]).forEach((m,i)=>{
    const r=tb.insertRow();
    td(r,`<input value="${m.milestone||''}" oninput="setMs(${i},'milestone',this.value)">`);
    td(r,`<input value="${m.start||''}" oninput="setMs(${i},'start',this.value)">`);
    td(r,`<input value="${m.end||''}" oninput="setMs(${i},'end',this.value)">`);
    td(r,`<button onclick="delMs(${i})">Delete</button>`);
  });

  const ch = data.schedule_10_chiller_performance||{};
  document.getElementById('ch').innerHTML = `
    <div>Basis of design: <input value="${ch.basis_of_design||''}" oninput="chSet('basis_of_design',this.value)"></div>
    <div>Quantity: <input value="${ch.quantity||''}" oninput="chSet('quantity',this.value)"></div>
    <div>Heating capacity (kWr): <input value="${ch.heating_capacity_kwr||''}" oninput="chSet('heating_capacity_kwr',this.value)"></div>
    <div>Control: <input value="${ch.control||''}" oninput="chSet('control',this.value)"></div>
  `;

  const pl=document.getElementById('pl');
  pl.innerHTML='<tr><th>Item</th><th>Details</th><th>ex GST</th><th>GST</th><th>inc GST</th><th></th></tr>';
  (data.schedule_10_pricing||[]).forEach((p,i)=>{
    const r=pl.insertRow();
    td(r,`<input value="${p.item_no||''}" oninput="setPl(${i},'item_no',this.value)">`);
    td(r,`<input style="width:100%" value="${p.details||''}" oninput="setPl(${i},'details',this.value)">`);
    td(r,`<input type="number" step="0.01" value="${p.price_ex_gst??''}" oninput="setPl(${i},'price_ex_gst',parseFloat(this.value)||null)">`);
    td(r,`<input type="number" step="0.01" value="${p.gst??''}" oninput="setPl(${i},'gst',parseFloat(this.value)||null)">`);
    td(r,`<input type="number" step="0.01" value="${p.price_inc_gst??''}" oninput="setPl(${i},'price_inc_gst',parseFloat(this.value)||null)">`);
    td(r,`<button onclick="delPl(${i})">Delete</button>`);
  });
}
function setMs(i,k,v){data.schedule_9_milestones[i][k]=v;}
function delMs(i){data.schedule_9_milestones.splice(i,1); render();}
function addMs(){(data.schedule_9_milestones=data.schedule_9_milestones||[]).push({milestone:''}); render();}
function chSet(k,v){data.schedule_10_chiller_performance[k]=v;}
function setPl(i,k,v){data.schedule_10_pricing[i][k]=v;}
function delPl(i){data.schedule_10_pricing.splice(i,1); render();}
function addPl(){(data.schedule_10_pricing=data.schedule_10_pricing||[]).push({item_no:'',details:''}); render();}

async function load(){ const r=await fetch('/records/'+recId+'/returnable_structured'); data=await r.json(); render(); }
async function save(){ await fetch('/records/'+recId+'/returnable_structured',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({data})}); alert('Saved'); }
load();
</script>
</body></html>
"""

@app.get("/", response_class=HTMLResponse)
def home():
    return HTMLResponse(HOME)

@app.get("/ui/returnable/{rec_id}", response_class=HTMLResponse)
def ui_returnable(rec_id: str):
    _ = load_record(rec_id)
    return HTMLResponse(EDITOR_RS)

@app.get("/ui/returnable2/{rec_id}", response_class=HTMLResponse)
def ui_returnable2(rec_id: str):
    _ = load_record(rec_id)
    return HTMLResponse(EDITOR_RS2)

@app.get("/ui/rft/{rec_id}", response_class=HTMLResponse)
def ui_rft(rec_id: str):
    _ = load_record(rec_id)
    return HTMLResponse(EDITOR_RFT)

@app.get("/ui/tepp/{rec_id}", response_class=HTMLResponse)
def ui_tepp(rec_id: str):
    _ = load_record(rec_id)
    return HTMLResponse(EDITOR_TEPP)
