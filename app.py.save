# -------------------- Helpers --------------------

def _add_unique_line(lst: List[str], line: Optional[str]):
    if not line: 
        return
    norm = re.sub(r"\s+", " ", line.strip().lower())
    if not norm: 
        return
    for x in lst:
        if re.sub(r"\s+", " ", x.strip().lower()) == norm:
            return
    lst.append(line.strip())

def _extend_unique(lst: List[str], lines: List[str]):
    for ln in lines or []:
        _add_unique_line(lst, ln)

def _llm(json_mode: bool = False):
    if LLM_PROVIDER.lower() == "ollama":
        kwargs = {"temperature": 0}
        if json_mode:
            kwargs["format"] = "json"
        return ChatOllama(base_url=OLLAMA_BASE_URL, model=OLLAMA_MODEL, **kwargs)
    if json_mode:
        return ChatOpenAI(
            model=OPENAI_MODEL, temperature=0, base_url=OPENAI_BASE_URL,
            model_kwargs={"response_format": {"type": "json_object"}},
        )
    return ChatOpenAI(model=OPENAI_MODEL, temperature=0, base_url=OPENAI_BASE_URL)

def _clean_json(s: str) -> str:
    s = s.strip()
    if s.startswith("```"):
        s = re.sub(r"^```json|^```", "", s).strip()
        s = re.sub(r"```$", "", s).strip()
    return s

def _extract_text(tmp: Path) -> str:
    ext = tmp.suffix.lower()
    if ext == ".pdf":
        doc = fitz.open(tmp)
        return "\n".join([doc.load_page(i).get_text("text") for i in range(len(doc))])
    if ext in (".docx",):
        return docx2txt.process(str(tmp)) or ""
    if ext in (".txt",):
        return tmp.read_text(encoding="utf-8", errors="ignore")
    raise HTTPException(400, "Unsupported file type. Upload PDF, DOCX, or TXT.")

def _chunks(text: str) -> List[str]:
    return SPLITTER.split_text(text)

def _faiss_path(doc_id: str) -> Path:
    return FAISS_DIR / f"{doc_id}"

def _chroma_name(doc_id: str) -> str:
    return f"spec-{doc_id}"

# -------------------- Vector store --------------------
def build_index(doc_id: str, chunks: List[str]):
    if VECTOR_BACKEND == "faiss_gpu":
        if not _FAISS_OK:
            raise HTTPException(500, "FAISS-GPU not available. Install faiss-gpu via conda.")
        vs = LCFAISS.from_texts(texts=chunks, embedding=EMBED)
        vs.save_local(str(_faiss_path(doc_id)))
        return
    Chroma.from_texts(
        texts=chunks, embedding=EMBED, persist_directory=str(INDEX_DIR),
        collection_name=_chroma_name(doc_id), client_settings=CHROMA_SETTINGS
    )

def get_vs(doc_id: str):
    if VECTOR_BACKEND == "faiss_gpu":
        if not _FAISS_OK:
            raise HTTPException(500, "FAISS-GPU not available.")
        vs = LCFAISS.load_local(
            str(_faiss_path(doc_id)), embeddings=EMBED, allow_dangerous_deserialization=True,
        )
        res = faiss.StandardGpuResources()
        vs.index = faiss.index_cpu_to_gpu(res, 0, vs.index)
        return vs
    return Chroma(
        embedding_function=EMBED, persist_directory=str(INDEX_DIR),
        collection_name=_chroma_name(doc_id), client_settings=CHROMA_SETTINGS,
    )

def _similar(vs, query: str, k: int = 6) -> List[str]:
    try:
        docs = vs.similarity_search(query, k=k)
        return [d.page_content for d in docs]
    except Exception:
        return []

def _try_parse_json(response: str) -> Any:
    s = _clean_json(response)
    try:
        return json.loads(s)
    except Exception:
        m = re.search(r"\{[\s\S]*\}$", response.strip())
        if not m:
            raise
        return json.loads(m.group(0))

