Return STRICT JSON matching the ReturnableStructured model described below. Fill wording that is policy/template-driven from the template; fill technical quantities from the spec (fans/coils/chillers/BACnet/warranty/schedule-of-performances).

JSON shape (keys):
header, schedule_1_corporate, schedule_2_financial, schedule_3_confidentiality_conflict,
schedule_4_key_personnel, schedule_5_insurance, schedule_6_previous_experience, schedule_7_current_council_clients, schedule_8_referees,
schedule_9_delivery_performance, schedule_9_milestones, schedule_9_subcontractors, schedule_9_questions,
schedule_10_fee_structure, schedule_10_chiller_performance, schedule_10_pricing,
schedule_11_csr, schedule_12_sustainability, schedule_13_eeo_fair,
schedule_14_whs, schedule_15_modern_slavery, schedule_16_addenda_ack,
supporting_documents_checklist.
"""

def rag_json(vs, prompt: str, field_queries: List[str], max_ctx: int = 6) -> Any:
    ctx_blocks = []
    for q in field_queries:
        snips = _similar(vs, q, k=max_ctx)
        if snips:
            ctx_blocks.append(f"[{q}]\n" + "\n---\n".join(snips))
    context = "\n\n".join(ctx_blocks) if ctx_blocks else "NO_CONTEXT"

    messages = [
        SystemMessage(content=prompt),
        HumanMessage(content=f"Context:\n{context}\n\nReturn ONLY the JSON object.")
    ]
    resp = _llm(json_mode=True).invoke(messages).content
    try:
        return _try_parse_json(resp)
    except Exception:
        repair = messages + [HumanMessage(content="Respond again as STRICT JSON only. No prose.")]
        resp2 = _llm(json_mode=True).invoke(repair).content
        return _try_parse_json(resp2)

# -------------------- Deterministic spec parsing (regex/heuristics) --------------------
NUM = r"(?:\d+(?:\.\d+)?)"
def _findall_lines(text: str, header_regex: str, stop_regex: str) -> List[str]:
    """Grab lines under a section header until stop section."""
    lines = text.splitlines()
    out, capture = [], False
    hdr = re.compile(header_regex, re.I)
    stp = re.compile(stop_regex, re.I)
    for ln in lines:
        if not capture and hdr.search(ln):
            capture = True
            continue
        if capture and stp.search(ln):
            break
        if capture:
            out.append(ln)
    return [l.rstrip() for l in out]

def _harvest_numbered(lines: List[str]) -> List[str]:
    items = []
    for l in lines:
        if re.match(r"^\s*(?:\d+[\).]|[a-z][\).]|•|-)\s+", l.strip(), re.I) or l.strip():
            items.append(l.strip(" -•\t"))
    return [x for x in (s.strip() for s in items) if x]

def parse_spec(text: str) -> Dict[str, Any]:
    # 1. General > bullet list
    general = _harvest_numbered(_findall_lines(text, r"^\s*1\.\s*GENERAL REQUIREMENTS", r"^\s*2\.\s*DESCRIPTION OF WORKS"))
    # 2.2.* subsections
    each_ahu = _harvest_numbered(_findall_lines(text, r"2\.2\.1\s+Each AHU Plenums", r"2\.2\.2"))
    mech = _harvest_numbered(_findall_lines(text, r"2\.2\.2\s+Mechanical", r"2\.2\.3"))
    bmcs = _harvest_numbered(_findall_lines(text, r"2\.2\.3\s+Upgrade of Building Management Control System", r"2\.2\.4"))
    chiller_inst = _harvest_numbered(_findall_lines(text, r"2\.2\.4\s+Chiller installation", r"2\.2\.5"))
    water_tx = _harvest_numbered(_findall_lines(text, r"2\.2\.5\s+Water Treatment", r"2\.2\.6"))
    electrical = _harvest_numbered(_findall_lines(text, r"2\.2\.6\s+Electrical", r"2\.2\.7"))
    general_works = _harvest_numbered(_findall_lines(text, r"2\.2\.7\s+General", r"^\s*3\."))

    # Equipment patterns
    chillers = []
    m = re.search(r"(Carrier\s*61WG190A).*?(\b212\b)\s*kW", text, re.I)
    if m:
        chillers.append({"make_model": m.group(1).strip(), "count": 2, "heating_capacity_kw": float(m.group(2))})
    else:
        if re.search(r"water[-\s]cooled heat pump chiller", text, re.I):
            chillers.append({"make_model": None, "count": 2, "heating_capacity_kw": None})

    ec_fans_count = 0
    m2 = re.search(r"(?:eight|\(8\)|\b8\b)\s+EC\s+plug", text, re.I)
    if m2: ec_fans_count = 8

    evaps = 0
    conds = 0
    hr_sets = 0
    m3 = re.search(r"four\s*\(\s*4\s*\)\s*new evaporator coils", text, re.I)
    if m3: evaps = 4
    m4 = re.search(r"two\s*\(\s*2\s*\)\s*condenser coils", text, re.I)
    if m4: conds = 2
    m5 = re.search(r"two\s*\(\s*2\s*\)\s*sets of new run[-\s]around heat recovery coils\s*\(4 in total\)", text, re.I)
    if m5: hr_sets = 2

    # Tests & commissioning (sec 10)
    tests = _harvest_numbered(_findall_lines(text, r"^\s*10\.\s*TESTING\s*&\s*COMMISSIONING", r"^\s*11\.\s*WARRANTY"))
    # Warranty (sec 11)
    warranty = None
    m6 = re.search(r"Warrant(?:y|ies).*?(\d+)\s*months?", text, re.I)
    if m6: warranty = int(m6.group(1))
    # Maintenance (sec 12)
    maintenance = _harvest_numbered(_findall_lines(text, r"^\s*12\.\s*MAINTENANCE\s*&\s*SERVICE", r"^\s*13\."))

    # WHS/PPE/Standards
    whs = []
    if re.search(r"WorkSafe\s*NSW|SafeWork\s*NSW", text, re.I): whs.append("Comply with SafeWork NSW / Council WHS")
    if re.search(r"PPE|personal protective equipment", text, re.I): whs.append("Provide PPE for all on-site workers")
    if re.search(r"AS/?NZS\s*3000|AS3000", text, re.I): whs.append("Electrical work to AS/NZS 3000")
    if re.search(r"ISO\s*9001", text, re.I): whs.append("Quality management to ISO 9001:2015")

    # Schedule of performances (sec 13)
    duty_flow = None; duty_head = None; voltage = None; pump_count = None
    m7 = re.search(r"Duty\s*Flow\s*([0-9.]+)\s*L/S", text, re.I)
    if m7: duty_flow = float(m7.group(1))
    m8 = re.search(r"Duty\s*Head\s*([0-9.]+)\s*M", text, re.I)
    if m8: duty_head = float(m8.group(1))
    m9 = re.search(r"(?:Power\s*Supply|Phase).*?(\d{3}/\d/\d{2})", text, re.I)
    if m9: voltage = m9.group(1)
    m10 = re.search(r"Number of Pumps\s*(\d+)", text, re.I)
    if m10: pump_count = int(m10.group(1))

    ec_table = []
    for row in re.findall(r"EF\s*\d-\d.*", text):
        vol = re.search(r"(\d{3,5})\s*(?:L/?s|\bLs\b)", row, re.I)
        stat = re.search(r"(\d{2,4})\s*Pa", row, re.I)
        volt = re.search(r"(?:3Ph/\s*\d{3}-\d{3}V|[23]Ph/\s*\d{3}-\d{3}V)", row, re.I)
        ec_table.append({
            "desc": row.strip(),
            "volume_ls": float(vol.group(1)) if vol else None,
            "static_pa": float(stat.group(1)) if stat else None,
            "voltage": volt.group(0) if volt else None
        })

    parsed = {
        "equipment": {
            "chillers": chillers,
            "ec_fans": {"count": ec_fans_count or None, "per_ahu": 4 if ec_fans_count==8 else None},
            "coils": {"evaporator_count": evaps or None, "condenser_count": conds or None, "heat_recovery_sets": hr_sets or None}
        },
        "bmcs": {"integration": bool(bmcs), "protocols": ["BACnet"] if re.search(r"BACnet|HLI", text, re.I) else []},
        "tests": [t for t in tests if t],
        "warranty_months": warranty,
        "maintenance": [m for m in maintenance if m],
        "whs": whs,
        "works_breakdown": {
            "decommission": [x for x in general if re.search(r"Removal|dispose|decommission", x, re.I)] + each_ahu,
            "mechanical": mech,
            "electrical": electrical,
            "ductwork": [x for x in general if re.search(r"duct", x, re.I)],
            "pipework": [x for x in general if re.search(r"pipe", x, re.I)],
            "cranage": [x for x in general if re.search(r"Cranage|Hoisting|lifting", x, re.I)] + chiller_inst,
            "general": general_works
        },
        "schedule_of_performances": {
            "pump": {"duty_flow_ls": duty_flow, "duty_head_m": duty_head, "voltage": voltage, "count": pump_count},
            "ec_fan": ec_table
        }
    }
    return parsed

# -------------------- Composition helpers --------------------
def _unique_keep_order(items: List[str]) -> List[str]:
    seen = set(); out = []
    for it in items:
        key = re.sub(r"\s+", " ", it.strip().lower())
        if key and key not in seen:
            seen.add(key); out.append(it.strip())
    return out

def compose_returnables(parsed: Dict[str, Any]) -> ReturnableScheduleDoc:
    eq = parsed.get("equipment", {})
    whs = parsed.get("whs", [])
    tests = parsed.get("tests", [])
    maint = parsed.get("maintenance", [])
    works = parsed.get("works_breakdown", {})
    perf = parsed.get("schedule_of_performances", {})

    tech_items = []
    if eq.get("chillers"):
        for ch in eq["chillers"]:
            mm = ch.get("make_model") or "Water-cooled heat pump chiller"
            cap = f"{int(ch['heating_capacity_kw'])} kW" if ch.get("heating_capacity_kw") else ""
            cnt = f"x{ch.get('count')}" if ch.get("count") else ""
            tech_items.append(f"Supply & install {cnt} {mm} {cap}".strip())
    coils = eq.get("coils", {})
    if coils.get("evaporator_count"): tech_items.append(f"{coils['evaporator_count']} new evaporator coils")
    if coils.get("condenser_count"): tech_items.append(f"{coils['condenser_count']} condenser coils")
    if coils.get("heat_recovery_sets"): tech_items.append(f"{coils['heat_recovery_sets']} sets of run-around heat recovery coils with pumps/VSDs")
    if eq.get("ec_fans", {}).get("count"):
        tech_items.append(f"{eq['ec_fans']['count']} EC plug exhaust fans (≈{eq['ec_fans'].get('per_ahu') or '?'} per AHU)")

    p = perf.get("pump") or {}
    if p.get("duty_flow_ls"): tech_items.append(f"Pump duty flow: {p['duty_flow_ls']} L/s")
    if p.get("duty_head_m"): tech_items.append(f"Pump duty head: {p['duty_head_m']} m")
    if p.get("voltage"): tech_items.append(f"Pump power supply: {p['voltage']}")
    for efr in perf.get("ec_fan", []):
        if efr.get("volume_ls"): tech_items.append(f"EC fan volume {int(efr['volume_ls'])} L/s")
        if efr.get("static_pa"): tech_items.append(f"EC fan static pressure {int(efr['static_pa'])} Pa")

    delivery_items = _unique_keep_order(
        (works.get("decommission") or []) +
        (works.get("mechanical") or []) +
        (works.get("electrical") or []) +
        (works.get("ductwork") or []) +
        (works.get("pipework") or []) +
        (works.get("cranage") or []) +
        (works.get("general") or [])
    )

    whs_items = _unique_keep_order(whs)
    quality_items = []
    if "ISO 9001:2015" in " ".join(whs):
        quality_items.append("Comply with ISO 9001:2015 quality management standards")
    if any(re.search(r"test|commission", t, re.I) for t in tests):
        quality_items.append("Provide Quality Plan incl. ITPs and commissioning records")

    warranty_items = []
    if parsed.get("warranty_months"):
        warranty_items.append(f"Minimum warranty: {parsed['warranty_months']} months on equipment & workmanship")
    warranty_items += maint

    tc_items = _unique_keep_order(tests)

    schedules = [
        Section(title="Schedule – Company Details", items=[]),
        Section(title="Schedule – Technical Requirements", items=_unique_keep_order(tech_items)),
        Section(title="Schedule – Delivery Performance", items=delivery_items[:50]),
        Section(title="Schedule – WHS & Safety", items=whs_items),
        Section(title="Schedule – Quality Management", items=_unique_keep_order(quality_items)),
        Section(title="Schedule – Warranty & Maintenance", items=_unique_keep_order(warranty_items)),
        Section(title="Schedule – Testing & Commissioning", items=tc_items),
    ]
    return ReturnableScheduleDoc(schedules=schedules)

def compose_rft(spec_summary: SpecSummary, parsed: Dict[str, Any]) -> RFTDoc:
    overview = []
    if spec_summary.title: overview.append(spec_summary.title)
    if spec_summary.location: overview.append(f"Location: {spec_summary.location}")
    if parsed.get("equipment", {}).get("chillers"):
        overview.append("Includes new/replacement heat pump chillers and AHU refurbishments")

    rs = compose_returnables(parsed)
    tech = [it for s in rs.schedules if "Technical Requirements" in s.title for it in s.items]

    resp_req = [
        "Complete all Returnable Schedules in the provided format",
        "Provide product data/catalogues & technical sheets for all proposed equipment",
        "Provide draft layout and connection diagrams",
        "Provide methodology/program and risk controls",
        "Provide warranty terms and service schedules"
    ]

    submission = []
    if spec_summary.closing_datetime:
        submission.append(f"Closing date and time: {spec_summary.closing_datetime}")

    header = {
        "tender_title": spec_summary.title,
        "tender_no": spec_summary.tender_no,
        "contract_no": spec_summary.contract_no,
        "closing_datetime": spec_summary.closing_datetime,
        "contact": (spec_summary.contact.model_dump() if spec_summary.contact else {"name": None, "email": None, "phone": None}),
        "lodgement_instructions": None
    }
    sections = [
        Section(title="Overview", items=_unique_keep_order(overview)),
        Section(title="Technical Scope Summary", items=tech[:80]),
        Section(title="Response Requirements", items=resp_req),
        Section(title="Submission & Closing", items=submission),
    ]
    return RFTDoc(header=header, sections=sections)

# -------------------- Policy support & dual-RAG --------------------
def _build_ephemeral_vs(texts: List[str]):
    """In-memory FAISS for policy/guideline docs (no persist)."""
    if not texts:
        return None
    return LCFAISS.from_texts(texts=texts, embedding=EMBED)

def _scan_policy_files() -> List[Path]:
    """Auto-pick up TEPP/Returnables/Evaluation docs from ./data (and /mnt/data if present)."""
    pats = ["tepp", "evaluation", "eval", "manual", "quotation", "returnable", "schedule", "part 5", "fee structure", "pricing"]
    roots = [DATA_DIR]
    try:
        mnt = Path("/mnt/data")
        if mnt.exists():
            roots.append(mnt)
    except Exception:
        pass
    out = []
    for root in roots:
        for p in root.glob("*"):
            name = p.name.lower()
            if any(k in name for k in pats) and p.suffix.lower() in (".pdf", ".docx", ".txt"):
                out.append(p)
    return out

def _extract_many(paths: List[Path]) -> List[str]:
    out = []
    for p in paths:
        try:
            out.append(_extract_text(p))
        except Exception:
            continue
    return out

def rag_json_plus(vs_primary, prompt: str, field_queries: List[str], extra_vss: Optional[List[Any]] = None, max_ctx: int = 6) -> Any:
    """RAG using primary VS + optional extra VSs (policy/guidelines)."""
    ctx_blocks = []
    for q in field_queries:
        snips = []
        snips += _similar(vs_primary, q, k=max_ctx)
        if extra_vss:
            for evs in extra_vss:
                try:
                    snips += _similar(evs, q, k=max(2, max_ctx // 2))
                except Exception:
                    pass
        if snips:
            ctx_blocks.append(f"[{q}]\n" + "\n---\n".join(snips))
    context = "\n\n".join(ctx_blocks) if ctx_blocks else "NO_CONTEXT"

    messages = [
        SystemMessage(content=prompt),
        HumanMessage(content=f"Context:\n{context}\n\nReturn ONLY the JSON object.")
    ]
    resp = _llm(json_mode=True).invoke(messages).content
    try:
        return _try_parse_json(resp)
    except Exception:
        repair = messages + [HumanMessage(content="Respond again as STRICT JSON only. No prose.")]
        resp2 = _llm(json_mode=True).invoke(repair).content
        return _try_parse_json(resp2)
    

def enrich_tepp_with_spec(tepp_json: Dict[str, Any], spec_summary: SpecSummary, parsed: Dict[str, Any]) -> Dict[str, Any]:
    tepp_json.setdefault("evaluation_methodology", {})
    tepp_json["evaluation_methodology"].setdefault("compliance_criteria", [])
    tepp_json["evaluation_methodology"].setdefault("required_criteria", [])
    tepp_json.setdefault("pricing", {})
    tepp_json["pricing"].setdefault("value_for_money", [])
    tepp_json.setdefault("probity_and_accountability", {})
    tepp_json["probity_and_accountability"].setdefault("risks", [])
    tepp_json.setdefault("evaluation_schedule", [])
    tepp_json.setdefault("critical_dates", [])
    tepp_json.setdefault("description", {"summary": [], "desired_outcomes": [], "purpose_rft": []})

    whs = parsed.get("whs", [])
    tests = parsed.get("tests", [])
    warranty_months = parsed.get("warranty_months")
    maintenance = parsed.get("maintenance", [])
    bmcs = parsed.get("bmcs", {})
    equip = parsed.get("equipment", {})

    # --- Description: inject a concise technical one-liner
    headline_bits = []
    if equip.get("chillers"):
        headline_bits.append("Replacement/upgrade of water-cooled heat pump chillers")
    if equip.get("coils", {}).get("evaporator_count") or equip.get("coils", {}).get("condenser_count"):
        headline_bits.append("AHU coil refurbishments")
    if equip.get("ec_fans", {}).get("count"):
        headline_bits.append(f"{equip['ec_fans']['count']} EC plug fans")
    if bmcs.get("integration"):
        headline_bits.append("BMCS integration (e.g., BACnet HLI)")
    summary_line = "Scope includes: " + "; ".join(headline_bits) if headline_bits else None
    if summary_line:
        _add_unique_line(tepp_json["description"]["summary"], summary_line)

    # --- Methodology: compliance criteria from WHS/tests
    for w in whs:
        _add_unique_line(tepp_json["evaluation_methodology"]["compliance_criteria"], w)
    if tests:
        _add_unique_line(tepp_json["evaluation_methodology"]["compliance_criteria"], "Provide commissioning plan and evidence of tests per Section 10")

    # --- Required criteria: enrich Methodology, WHS, Quality descriptions
    req = tepp_json["evaluation_methodology"]["required_criteria"]
    # map for quick find-or-create
    def _get_req(name_prefix: str, default_weight: float, mandatory: bool=False):
        for r in req:
            if r.get("name","").lower().startswith(name_prefix.lower()):
                return r
        r = {"name": name_prefix, "weight": default_weight, "description": "", "mandatory": mandatory}
        req.append(r)
        return r

    meth = _get_req("Methodology", 12.5)
    qms  = _get_req("Quality", 5.0)
    whs_c = _get_req("Work Health & Safety", 5.0, mandatory=True)

    # Methodology description: tests + BMCS + staging
    meth_lines = []
    if tests: 
        meth_lines.append("Commissioning plan covering: " + "; ".join(tests[:6]) + ("…" if len(tests) > 6 else ""))
    if bmcs.get("integration"):
        proto = ", ".join(bmcs.get("protocols") or [])
        meth_lines.append(f"BMCS integration/HLI ({proto}) with IO schedules and point lists")
    if warranty_months:
        meth_lines.append(f"Program includes defects liability / warranty of {warranty_months} months")
    if maintenance:
        meth_lines.append("Provision for service/maintenance handover & schedules")
    meth["description"] = "; ".join([s for s in meth_lines if s])

    # Quality description (ITPs + performance)
    qms_desc = qms.get("description") or ""
    _extend_unique(tepp_json["evaluation_methodology"]["compliance_criteria"], ["Quality plan incl. ITPs"])
    qms_desc_bits = [qms_desc] if qms_desc else []
    qms_desc_bits.append("Quality plan incl. ITPs; as-built docs; performance verification")
    qms["description"] = "; ".join(_unique_keep_order(qms_desc_bits))

    # WHS description
    if whs:
        whs_c["mandatory"] = True
        whs_c["description"] = "; ".join(_unique_keep_order(whs))

    # --- Pricing / Value for Money
    if maintenance or warranty_months:
        _add_unique_line(tepp_json["pricing"]["value_for_money"], "Consider whole-of-life costs incl. maintenance and warranty obligations")
    if equip.get("chillers"):
        _add_unique_line(tepp_json["pricing"]["value_for_money"], "Energy efficiency and control strategy for chillers/AHUs")

    # --- Risks (deterministic seeds)
    risks = tepp_json["probity_and_accountability"]["risks"]
    def _risk(issue, consequence, action):
        risks.append({"issue": issue, "consequence": consequence, "action": action})
    if bmcs.get("integration"):
        _risk("BMCS integration failure", "Loss of monitoring/control", "Factory acceptance test; point-to-point I/O test; SAT with witness")
    if equip.get("ec_fans", {}).get("count"):
        _risk("EC fan performance shortfall", "Insufficient airflow/pressure", "Verify duty against schedule; commissioning with TAB report")
    if warranty_months:
        _risk("Warranty service response", "Extended downtime", "Specify response/rectification times and contacts in contract")

    # --- Evaluation schedule (seed from spec items)
    sched = tepp_json["evaluation_schedule"]
    def _sched(task):
        sched.append({"task": task, "responsible": None, "due": None})
    if tests:
        _sched("Review Testing & Commissioning plan and witness tests")
    if maintenance:
        _sched("Review maintenance schedules and O&M handover")
    if bmcs.get("integration"):
        _sched("Review BMCS HLI/point list and integration test records")

    # --- Critical dates
    if spec_summary and spec_summary.closing_datetime:
        _add_unique_line(tepp_json["critical_dates"], f"RFT Closing: {spec_summary.closing_datetime}")

    return tepp_json


# -------------------- TEPP composer (policy + spec) --------------------
def compose_tepp(spec_summary: SpecSummary, parsed: Dict[str, Any], vs_spec, extra_vss: Optional[List[Any]]) -> TEPPDoc:
    tepp_json = rag_json_plus(
        vs_spec,
        TEPP_PROMPT,
field_queries=[
    # pull SPEC by exact section keys used in your docs
    "10. TESTING & COMMISSIONING", "11. WARRANTY", "12. MAINTENANCE & SERVICE",
    "WHS PPE ISO", "BACnet High Level Interface BMCS integration",
    "2. DESCRIPTION OF WORKS", "2.2 Mechanical Electrical Cranage General",
    "13. SCHEDULE OF PERFORMANCES EC fans pumps voltage",

    # pull POLICY/TEMPLATE shape
    "TEPP Aim", "Description of Requirement", "Desired Outcomes", "Purpose of RFT",
    "Probity and Accountability", "Authorised Contact Officer", "Receipt of tenders",
    "Late tenders", "Requests for Clarification", "Critical issues or risks",
    "Evaluation Committee", "Evaluation Schedule",
    "Evaluation Methodology compliance criteria required criteria rating scale",
    "Returnable schedules scoring Relevant Experience Capability Quality WHS",
    "Pricing model normalised price score weighted price score",
    "Local preference policy Blacktown LGA Western Sydney",
    "Value for Money", "Interviews and Presentations", "Short-listing", "Alternative Tenders",
    "Tenderer Presentations", "Evaluation Report", "Contract Negotiations",
    "Debriefing of unsuccessful tenderers", "Contract Management", "Critical dates"
],

        extra_vss=extra_vss,
        max_ctx=8
    )

    # Fill header defaults from spec summary
    tepp_json.setdefault("header", {})
    tepp_json["header"].setdefault("project_title", spec_summary.title)
    tepp_json["header"].setdefault("tender_no", spec_summary.tender_no)

    # <<< NEW: harden with deterministic spec enrichment >>>
    tepp_json = enrich_tepp_with_spec(tepp_json, spec_summary, parsed)

    # Back-compat mirrors
    tepp_json.setdefault("evaluation_criteria", tepp_json.get("evaluation_methodology", {}).get("required_criteria", []))
    tepp_json.setdefault("probity", tepp_json.get("probity_and_accountability", {}))
    tepp_json.setdefault("milestones", tepp_json.get("critical_dates", []))

    return TEPPDoc.model_validate(tepp_json)

# -------------------- NEW: Structured Returnables composer + summary --------------------
def compose_returnables_tepp(spec_summary: SpecSummary, parsed: Dict[str, Any], vs_spec, extra_vss: Optional[List[Any]]) -> ReturnableStructured:
    rs_json = rag_json_plus(
        vs_spec,
        RETURNABLE_TEPP_PROMPT,
        field_queries=[
            "Returnable Schedules Schedule 1 Corporate information & Declaration",
            "Schedule 2 Financial capacity",
            "Schedule 3 Confidentiality and Conflict of Interest",
            "Schedule 4 Key personnel",
            "Schedule 5 Insurance",
            "Schedule 6 Previous experience",
            "Schedule 7 Current council clients",
            "Schedule 8 Referees",
            "Schedule 9 Delivery performance milestones subcontractors questions",
            "Schedule 10 Fee structure pricing tables Schedule of Performance Heat Pump Chillers",
            "Schedule 11 Corporate social responsibility",
            "Schedule 12 Sustainability",
            "Schedule 13 EEO & fair employment",
            "Schedule 14 Work, health & safety (WHS) forms appendices",
            "Schedule 15 Modern Slavery",
            "Schedule 16 Acknowledgement receipt of addenda and tenderer’s declaration",
            "Supporting documents checklist",
            # Spec technical anchors
            "BACnet HLI gateway BMCS integration",
            "Testing & Commissioning",
            "Warranty Maintenance Service 12 months",
            "Schedule of Performances pump EC fan coil",
            "Carrier 61WG190A 212 kW",
        ],
        extra_vss=extra_vss,
        max_ctx=10
    )

    rs = ReturnableStructured.model_validate(rs_json)

    # ---- Header seeding ----
    rs.header.setdefault("tender_title", spec_summary.title)
    rs.header.setdefault("tender_no", spec_summary.tender_no)
    rs.header.setdefault("contract_no", spec_summary.contract_no)

    # ---- Schedule 9 milestones (template seeds) ----
    template_ms = [
        "Site establishment, safety and access preparation",
        "Removal of redundant equipment (fans, exchangers etc.)",
        "Pouring and curing of concrete plinths for chillers",
        "Delivery and installation of new chillers",
        "AHU 1 & 3 internal plenum modification",
        "Installation of coils, drift eliminators, and sumps",
        "Supply & install EC fans and new access panels",
        "Pipework and ductwork modifications",
        "Electrical upgrades and cabling works",
        "BMS integration and BACnet configuration",
        "Testing and commissioning",
        "Handover, documentation, and practical completion",
        "12-month defect liability and maintenance period begins",
    ]
    have = {m.milestone.strip().lower() for m in rs.schedule_9_milestones or [] if m.milestone}
    for m in template_ms:
        if m.strip().lower() not in have:
            rs.schedule_9_milestones.append(RS_DeliveryMilestone(milestone=m))

    # Critical date seed
    if "critical_dates" not in rs.schedule_9_delivery_performance:
        rs.schedule_9_delivery_performance["critical_dates"] = []
    _add_unique_line(rs.schedule_9_delivery_performance["critical_dates"], "Start of operation: 25 Aug 2025")

    # ---- Schedule 10 – performance/pricing enrichment ----
    ch = rs.schedule_10_chiller_performance
    eq = parsed.get("equipment", {})
    if eq.get("chillers"):
        c0 = eq["chillers"][0]
        if c0.get("make_model"):
            ch.basis_of_design = c0["make_model"]
        if c0.get("count"):
            ch.quantity = c0["count"]
        if c0.get("heating_capacity_kw"):
            ch.heating_capacity_kwr = float(c0["heating_capacity_kw"])
    ch.type = ch.type or "Water source heat pump chiller"
    ch.refrigerant = ch.refrigerant or "R410a"
    ch.compressors = ch.compressors or "Four (4) off scroll compressors"
    ch.start_method = ch.start_method or "‘Soft’ start with phase loss sensing"
    ch.chilled_water_flow_ls = ch.chilled_water_flow_ls or 5.75
    ch.chilled_water_temp_in_out = ch.chilled_water_temp_in_out or "12.2/5.6 °C"
    ch.ambient_db_summer_c = ch.ambient_db_summer_c or 35.0
    ch.evaporator_fluid = ch.evaporator_fluid or "Fresh Water"
    ch.condenser_flow_ls = ch.condenser_flow_ls or 10.2
    ch.condenser_temp_in_out = ch.condenser_temp_in_out or "45/50 °C"
    ch.ambient_db_winter_c = ch.ambient_db_winter_c or 7.0
    if not ch.control and parsed.get("bmcs", {}).get("integration"):
        ch.control = "Must be fitted with BACnet over IP gateway"

    if not rs.schedule_10_pricing:
        base_lines = [
            ("1.0", "Removal and disposal of redundant services including fans and exchangers"),
            ("2.0", "Supply, deliver and install (2) water-cooled chillers with inbuilt pumps and BACnet HLI card"),
            ("3.0", "Supply, deliver and install (8) EC fans, doors, panels, louvres"),
            ("4.0", "Supply and install coils: evaporator (4), condenser (2), run-around (4), and pumps (2)"),
            ("5.0", "Supply and install insulated copper pipes & fittings with metal cladding and all associated valves"),
            ("6.0", "Modify, supply and install exhaust ductwork"),
            ("7.0", "Modify and make good AHUs’ internal plenum, rust treatment, patching"),
            ("8.0", "All electrical works in Plantroom 1 for AHU 1 & 3 upgrades"),
            ("9.0", "Project preliminaries and documentation"),
            ("10.0", "Maintenance for twelve months"),
        ]
        rs.schedule_10_pricing = [RS_PriceLine(item_no=i, details=d) for i, d in base_lines]

    rs.schedule_14_whs.setdefault("forms_required", ["Appendix 1–3 WHS forms as per template"])
    rs.schedule_10_fee_structure.setdefault("terms", [
        "Prices in AUD; same regardless of payment mode; lump sum basis",
        "Prices available for acceptance during Validity Period",
        "Include GST, levies, duties, out-of-pocket expenses within NSW",
    ])
    if parsed.get("warranty_months"):
        _add_unique_line(rs.schedule_10_fee_structure.setdefault("notes", []),
                         f"Warranty: minimum {parsed['warranty_months']} months (equipment & installation)")
    if parsed.get("maintenance"):
        _add_unique_line(rs.schedule_10_fee_structure.setdefault("notes", []),
                         "Include 12 monthly maintenance visits during DLP")

    rs.supporting_documents_checklist = rs.supporting_documents_checklist or [
        "Certificates of currency for insurances",
        "CVs for key personnel; licences/tickets",
        "Financial statements (last 3 years)",
        "Certificates of third-party accreditation",
        "Quality Management Plan + ITPs",
        "WHS policy/plan + SWMS + checklists",
        "Environmental policy & plan",
        "EEO policy & industrial awards",
    ]
    return rs

def _structured_to_sections(rs: ReturnableStructured) -> ReturnableScheduleDoc:
    """Summarise the structured Returnables into the simple list-of-sections for the current UI."""
    items = []

    ms = [f"{m.milestone}" for m in (rs.schedule_9_milestones or [])]
    if ms:
        items.append(Section(title="Schedule 9 – Delivery performance (milestones)", items=ms))

    price_lines = [f"{pl.item_no}. {pl.details}" for pl in (rs.schedule_10_pricing or [])]
    if price_lines:
        items.append(Section(title="Schedule 10 – Fee Structure (pricing items)", items=price_lines))

    ch = rs.schedule_10_chiller_performance
    ch_short = []
    if ch.quantity: ch_short.append(f"Quantity: {ch.quantity}")
    if ch.basis_of_design: ch_short.append(f"Basis of design: {ch.basis_of_design}")
    if ch.heating_capacity_kwr: ch_short.append(f"Heating capacity: {int(ch.heating_capacity_kwr)} kWr")
    if ch.control: ch_short.append(ch.control)
    if ch_short:
        items.append(Section(title="Schedule 10 – Chiller performance (key data)", items=ch_short))

    if rs.schedule_14_whs:
        items.append(Section(title="Schedule 14 – WHS", items=list(rs.schedule_14_whs.keys())))
    if rs.supporting_documents_checklist:
        items.append(Section(title="Supporting documents checklist", items=rs.supporting_documents_checklist))

    return ReturnableScheduleDoc(schedules=items or [Section(title="Returnables", items=[])])

# -------------------- Extraction orchestrator --------------------
def extract_all(doc_id: str, raw_text: str) -> Tuple[SpecSummary, ReturnableScheduleDoc, RFTDoc, TEPPDoc, Dict[str, List[str]], ReturnableStructured]:
    vs = get_vs(doc_id)

    summary = rag_json(
        vs, SPEC_SUMMARY_PROMPT,
        [
            "tender title or document title",
            "tender number or contract number",
            "closing date and time",
            "contact name email phone",
            "scope of works",
            "location site",
            "safety standards ADR WHS ISO Australian Standards"
        ],
    )
    spec_summary = SpecSummary.model_validate(summary)

    parsed = parse_spec(raw_text)

    # Policy/template context for TEPP & Returnables (auto-scan ./data and /mnt/data)
    policy_files = _scan_policy_files()
    policy_texts = _extract_many(policy_files)
    policy_chunks = []
    for t in policy_texts:
        policy_chunks.extend(_chunks(t))
    vs_policy = _build_ephemeral_vs(policy_chunks) if policy_chunks else None
    extra_vss = [vs_policy] if vs_policy else []

    # --- NEW: structured returnables via TEPP-like RAG + enrichment
    rs_structured = compose_returnables_tepp(spec_summary, parsed, vs, extra_vss)

    # Keep the old section list for existing UI (summary from structured)
    returnable = _structured_to_sections(rs_structured)

    rft = compose_rft(spec_summary, parsed)
    tepp = compose_tepp(spec_summary, parsed, vs, extra_vss)

    # Citations / sample snippets for traceability (simple)
    cits = {
        "testing_commissioning": _similar(vs, "TESTING & COMMISSIONING", 3),
        "warranty": _similar(vs, "WARRANTY 12 months", 2),
        "bmcs": _similar(vs, "BACnet High Level Interface", 2),
        "equipment": _similar(vs, "EC plug fans Carrier 61WG190A chiller", 4),
        "schedule_of_performances": _similar(vs, "SCHEDULE OF PERFORMANCES", 3),
    }

    # Debug: ensure TEPP contains spec-derived content
    if not tepp.evaluation_methodology.get("compliance_criteria"):
        print("[TEPP] Warning: no compliance_criteria after enrichment")
    if not tepp.evaluation_schedule:
        print("[TEPP] Info: no evaluation_schedule seeds found")
    return spec_summary, returnable, rft, tepp, cits, rs_structured

# -------------------- Persistence --------------------
def save_record(rec: Record):
    p = DATA_DIR / f"{rec.id}.json"
    with open(p, "w") as f:
        json.dump(rec.model_dump(), f, indent=2)

def load_record(rec_id: str) -> Record:
    p = DATA_DIR / f"{rec_id}.json"
    if not p.exists():
        raise HTTPException(404, "Record not found")
    with open(p) as f:
        return Record.model_validate(json.load(f))

# -------------------- API --------------------
@app.post("/upload", response_model=Record)
async def upload(file: UploadFile = File(...)):
    doc_id = str(uuid.uuid4())
    suffix = Path(file.filename).suffix
    tmp = DATA_DIR / f"{doc_id}{suffix}"
    with open(tmp, "wb") as f:
        shutil.copyfileobj(file.file, f)

    text = _extract_text(tmp)
    if not text.strip():
        raise HTTPException(400, "Could not read text from the document.")
    chunks = _chunks(text)
    build_index(doc_id, chunks)

    spec_summary, returnable, rft, tepp, cits, rs_structured = extract_all(doc_id, text)

    now = datetime.utcnow().isoformat()
    rec = Record(
        id=doc_id,
        created_at=now, updated_at=now,
        file_name=file.filename,
        source_type=suffix.lower(),
        vs_backend=VECTOR_BACKEND,
        vs_location=str(_faiss_path(doc_id) if VECTOR_BACKEND=="faiss_gpu" else _chroma_name(doc_id)),
        spec_summary=spec_summary,
        returnable=returnable,
        rft=rft,
        tepp=tepp,
        citations=cits,
        status="draft",
        raw_excerpt=text[:2000],
        returnable_structured=rs_structured,
    )
    save_record(rec)
    return rec

@app.get("/records/{rec_id}", response_model=Record)
def get_record(rec_id: str):
    return load_record(rec_id)

@app.get("/records/{rec_id}/returnable", response_model=ReturnableScheduleDoc)
def get_returnable(rec_id: str):
    return load_record(rec_id).returnable

@app.get("/records/{rec_id}/returnable_structured", response_model=ReturnableStructured)
def get_returnable_structured(rec_id: str):
    rec = load_record(rec_id)
    if rec.returnable_structured is None:
        return ReturnableStructured()
    return rec.returnable_structured

@app.get("/records/{rec_id}/rft", response_model=RFTDoc)
def get_rft(rec_id: str):
    return load_record(rec_id).rft

@app.get("/records/{rec_id}/tepp", response_model=TEPPDoc)
def get_tepp(rec_id: str):
    return load_record(rec_id).tepp

# edits
class PatchPayload(BaseModel):
    data: Dict[str, Any]
    status: Optional[str] = None

def _merge(a: Any, b: Any) -> Any:
    if isinstance(a, dict) and isinstance(b, dict):
        out = a.copy(); out.update(b); return out
    return b

@app.patch("/records/{rec_id}/returnable", response_model=ReturnableScheduleDoc)
def patch_returnable(rec_id: str, payload: PatchPayload):
    rec = load_record(rec_id)
    rec.returnable = ReturnableScheduleDoc.model_validate(_merge(rec.returnable.model_dump(), payload.data))
    if payload.status: rec.status = payload.status
    rec.updated_at = datetime.utcnow().isoformat()
    save_record(rec)
    return rec.returnable

@app.patch("/records/{rec_id}/returnable_structured", response_model=ReturnableStructured)
def patch_returnable_structured(rec_id: str, payload: PatchPayload):
    rec = load_record(rec_id)
    merged = _merge(rec.returnable_structured.model_dump() if rec.returnable_structured else {}, payload.data)
    rec.returnable_structured = ReturnableStructured.model_validate(merged)
    if payload.status:
        rec.status = payload.status
    rec.updated_at = datetime.utcnow().isoformat()
    save_record(rec)
    return rec.returnable_structured

@app.patch("/records/{rec_id}/rft", response_model=RFTDoc)
def patch_rft(rec_id: str, payload: PatchPayload):
    rec = load_record(rec_id)
    rec.rft = RFTDoc.model_validate(_merge(rec.rft.model_dump(), payload.data))
    if payload.status: rec.status = payload.status
    rec.updated_at = datetime.utcnow().isoformat()
    save_record(rec)
    return rec.rft

@app.patch("/records/{rec_id}/tepp", response_model=TEPPDoc)
def patch_tepp(rec_id: str, payload: PatchPayload):
    rec = load_record(rec_id)
    rec.tepp = TEPPDoc.model_validate(_merge(rec.tepp.model_dump(), payload.data))
    if payload.status: rec.status = payload.status
    rec.updated_at = datetime.utcnow().isoformat()
    save_record(rec)
    return rec.tepp

# -------------------- GPU health & simple UI --------------------
@app.get("/gpu")
def gpu_health():
    info = {
        "torch_cuda_available": bool(torch.cuda.is_available()),
        "torch_cuda_device_count": torch.cuda.device_count() if torch.cuda.is_available() else 0,
        "faiss_available": _FAISS_OK,
        "faiss_num_gpus": faiss.get_num_gpus() if _FAISS_OK else 0,
        "llm_provider": LLM_PROVIDER,
        "ollama_base_url": OLLAMA_BASE_URL,
        "ollama_model": OLLAMA_MODEL,
        "vector_backend": VECTOR_BACKEND,
    }
    return info

