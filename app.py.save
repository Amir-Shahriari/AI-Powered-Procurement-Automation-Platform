# -------------------- Domain models --------------------
class Contact(BaseModel):
    name: Optional[str] = None
    email: Optional[str] = None
    phone: Optional[str] = None

class Section(BaseModel):
    title: str
    items: List[str] = Field(default_factory=list)

class SpecSummary(BaseModel):
    title: Optional[str] = None
    tender_no: Optional[str] = None
    contract_no: Optional[str] = None
    closing_datetime: Optional[str] = None
    contact: Optional[Contact] = None
    scope: List[str] = Field(default_factory=list)
    location: Optional[str] = None
    safety_standards: List[str] = Field(default_factory=list)

class ReturnableScheduleDoc(BaseModel):
    schedules: List[Section] = Field(default_factory=list)

class RFTDoc(BaseModel):
    header: Dict[str, Any] = Field(default_factory=dict)
    sections: List[Section] = Field(default_factory=list)

# -------- TEPP extended models --------
class CommitteeMember(BaseModel):
    name: Optional[str] = None
    title: Optional[str] = None
    branch: Optional[str] = None
    role: Optional[str] = None  # Chair, Member, Advisor

class ScheduleItem(BaseModel):
    task: str
    responsible: Optional[str] = None
    due: Optional[str] = None

class ScoringRubric(BaseModel):
    levels: List[Dict[str, Any]] = Field(default_factory=list)  # [{level, requirement, score}...]

class TEPPDoc(BaseModel):
    # existing fields for back-compat
    header: Dict[str, Any] = Field(default_factory=dict)
    evaluation_criteria: List[Dict[str, Any]] = Field(default_factory=list)
    probity: Dict[str, Any] = Field(default_factory=dict)
    milestones: List[str] = Field(default_factory=list)

    # new structured sections to mirror Council TEPP
    aim: List[str] = Field(default_factory=list)
    description: Dict[str, Any] = Field(default_factory=dict)  # {"summary": [...], "desired_outcomes": [...], "purpose_rft": [...]}
    probity_and_accountability: Dict[str, Any] = Field(default_factory=dict)  # {"authorised_contact_officer":{}, "receipt_of_tenders":[...], "late_tenders":[...], "clarifications":[...], "risks":[{issue, consequence, action}]}
    evaluation_committee: List[CommitteeMember] = Field(default_factory=list)
    evaluation_schedule: List[ScheduleItem] = Field(default_factory=list)
    evaluation_methodology: Dict[str, Any] = Field(default_factory=dict)  # {"compliance_criteria":[...], "required_criteria":[...], "rating_scale":[...]}
    returnable_scoring: Dict[str, ScoringRubric] = Field(default_factory=dict)  # per-criterion rubrics
    pricing: Dict[str, Any] = Field(default_factory=dict)  # {"model": {...}, "local_preference_policy": {...}, "value_for_money":[...]}
    interviews_presentations: List[str] = Field(default_factory=list)
    shortlisting_alternatives: List[str] = Field(default_factory=list)
    evaluation_report: List[str] = Field(default_factory=list)
    contract_negotiations: List[str] = Field(default_factory=list)
    debriefing: List[str] = Field(default_factory=list)
    contract_management: List[str] = Field(default_factory=list)
    critical_dates: List[str] = Field(default_factory=list)

