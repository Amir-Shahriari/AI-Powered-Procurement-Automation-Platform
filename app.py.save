HOME = r"""
<!doctype html>
<html>
<head>
<meta charset="utf-8"/>
<title>Spec → Returnable + RFT + TEPP (CUDA)</title>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<style>
  body{font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;max-width:1100px;margin:22px auto;padding:0 16px}
  .card{border:1px solid #ddd;border-radius:12px;padding:16px;margin:10px 0}
  .btn{padding:9px 14px;border:0;border-radius:10px;background:#111;color:#fff;cursor:pointer;text-decoration:none;display:inline-block}
  .ok{color:#0a7;font-weight:600}.err{color:#c33;font-weight:600}
  input[type=text], textarea{width:100%;padding:10px;border:1px solid #ccc;border-radius:8px}
  pre{background:#f7f7f7;padding:10px;border-radius:8px;overflow:auto}
</style>
</head>
<body>
  <h2>Specification → Three Outputs</h2>
  <div class="card">
    <form id="up">
      <label>Upload specification (PDF/DOCX/TXT)</label>
      <input type="file" id="f" required/>
      <button class="btn">Generate</button>
      <span id="msg"></span>
    </form>
  </div>

  <div id="links" class="card" style="display:none">
    <h3>Outputs</h3>
    <div>Record ID: <span id="rid"></span></div>
    <div style="margin-top:10px">
      <a id="a_rs" class="btn" href="#">Open Returnable Schedule</a>
      <a id="a_rs2" class="btn" href="#">Open Returnables (Structured)</a>
      <a id="a_rft" class="btn" href="#">Open RFT</a>
      <a id="a_tepp" class="btn" href="#">Open TEPP</a>
    </div>
    <details style="margin-top:10px">
      <summary>Spec summary & citations</summary>
      <pre id="summary"></pre>
    </details>
  </div>

<script>
let rec = null;

async function hydrate(recId){
  try{
    const r = await fetch('/records/'+recId);
    if(!r.ok) return false;
    rec = await r.json();
    document.getElementById('links').style.display = 'block';
    document.getElementById('rid').textContent = rec.id;
    document.getElementById('summary').textContent =
      JSON.stringify(rec.spec_summary, null, 2) +
      "\\n\\nCitations (sample):\\n" + JSON.stringify(rec.citations, null, 2);
    document.getElementById('a_rs').href = '/ui/returnable/' + rec.id;
    document.getElementById('a_rs2').href = '/ui/returnable2/' + rec.id;
    document.getElementById('a_rft').href = '/ui/rft/' + rec.id;
    document.getElementById('a_tepp').href = '/ui/tepp/' + rec.id;
    return true;
  }catch(e){ return false; }
}

async function initFromQueryOrStorage(){
  const params = new URLSearchParams(location.search);
  const qid = params.get('recId');
  if(qid && await hydrate(qid)){
    localStorage.setItem('lastRecId', qid);
    return;
  }
  const last = localStorage.getItem('lastRecId');
  if(last) await hydrate(last);
}

document.getElementById('up').addEventListener('submit', async (e)=>{
  e.preventDefault();
  const file = document.getElementById('f').files[0];
  if(!file) return;
  document.getElementById('msg').textContent = 'Uploading & generating…';
  const fd = new FormData();
  fd.append('file', file);
  try{
    const r = await fetch('/upload', {method:'POST', body:fd});
    if(!r.ok) throw new Error(await r.text());
    rec = await r.json();
    document.getElementById('msg').innerHTML = '<span class="ok">Done.</span>';
    document.getElementById('links').style.display = 'block';
    document.getElementById('rid').textContent = rec.id;
    document.getElementById('summary').textContent = JSON.stringify(rec.spec_summary, null, 2)
      + "\\n\\nCitations (sample):\\n" + JSON.stringify(rec.citations, null, 2);
    document.getElementById('a_rs').href = '/ui/returnable/' + rec.id;
    document.getElementById('a_rs2').href = '/ui/returnable2/' + rec.id;
    document.getElementById('a_rft').href = '/ui/rft/' + rec.id;
    document.getElementById('a_tepp').href = '/ui/tepp/' + rec.id;
    localStorage.setItem('lastRecId', rec.id);
    if(history && history.replaceState){
      const url = new URL(location.href);
      url.searchParams.set('recId', rec.id);
      history.replaceState(null, '', url.toString());
    }
  }catch(err){
    document.getElementById('msg').innerHTML = '<span class="err">'+err+'</span>';
  }
});

initFromQueryOrStorage();
</script>
</body>
</html>
"""

EDITOR_RS = r"""
<!doctype html><html><head><meta charset="utf-8"/>
<title>Returnable Schedule</title><meta name="viewport" content="width=device-width, initial-scale=1"/>
<style>
body{font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;max-width:1100px;margin:22px auto;padding:0 16px}
.card{border:1px solid #ddd;border-radius:12px;padding:16px;margin:10px 0}
.btn{padding:8px 12px;border:0;border-radius:10px;background:#111;color:#fff;cursor:pointer;text-decoration:none;display:inline-block}
input[type=text], textarea{width:100%;padding:10px;border:1px solid #ccc;border-radius:8px}
h3{margin:0 0 10px}
.nav{display:flex;gap:8px;align-items:center;margin-bottom:10px}
</style></head><body>
<div class="nav">
  <a id="back" class="btn" href="#">← Back</a>
  <h2 style="margin:0">Returnable Schedule</h2>
</div>
<div id="root"></div>
<script>
const recId = location.pathname.split('/').pop();
document.getElementById('back').href = '/?recId=' + encodeURIComponent(recId);

let data=null;
function row(idx, s){
  return `
  <div class="card">
    <h3 contenteditable oninput="editTitle(${idx}, this.innerText)">${s.title || 'Untitled Schedule'}</h3>
    <textarea oninput="editItems(${idx}, this.value)" rows="8">${(s.items||[]).join('\\n')}</textarea>
  </div>`;
}
function render(){
  const r = data.schedules.map((s,i)=>row(i,s)).join('');
  document.getElementById('root').innerHTML = `
    <div style="margin:8px 0">
      <button class="btn" onclick="save()">Save</button>
      <a class="btn" href="/?recId=${recId}">Back to Home</a>
      <button class="btn" style="background:#555" onclick="add()">Add Schedule</button>
    </div>
    ${r}
  `;
}
function editTitle(i, v){ data.schedules[i].title = v.trim(); }
function editItems(i, v){ data.schedules[i].items = v.split('\\n').map(x=>x.trim()).filter(Boolean); }

async function load(){
  const r = await fetch('/records/'+recId+'/returnable');
  data = await r.json();
  render();
}
function add(){ data.schedules.push({title:"New Schedule", items:[]}); render(); }
async function save(){
  await fetch('/records/'+recId+'/returnable', {
    method:'PATCH', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({data})
  });
  alert('Saved');
}
load();
</script></body></html>
"""

